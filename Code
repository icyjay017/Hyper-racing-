// Menu Scene
class MenuScene extends Phaser.Scene {
    constructor() {
        super({ key: 'MenuScene' });
    }

    preload() {
        // Load assets
    }

    create() {
        // Create menu elements
        this.add.text(100, 100, 'Menu', { fontSize: '32px', fill: '#fff' });
        this.input.on('pointerdown', () => this.scene.start('CustomizeScene'));
    }
}

// Customize Scene
